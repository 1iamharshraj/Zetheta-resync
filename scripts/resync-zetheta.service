[Unit]
Description=Zetheta Resync Web Service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/zetheta-resync
Environment="PATH=/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=/opt/zetheta-resync/.env
ExecStart=/opt/zetheta-resync/scripts/start.sh
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
