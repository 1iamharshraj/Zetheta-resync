# Zetheta update_submissions app code / API key
APP_CODE=S5PPbBvwHkZe16CvXJsykfpATsd8QZZVxms6uHfA1jAviEC4XjBPPZe1RucYCPdf

# Flask service settings
FLASK_PORT=5000

# Loki URL (the systemd service runs on the host, so use localhost; Docker Compose overrides this to http://loki:3100)
LOKI_URL=http://localhost:3100

# Where run result CSVs are written
RUN_OUTPUT_DIR=./runs

# Gunicorn workers (set to 1 for single-core VM setups to minimise CPU usage)
WORKERS=1

# Optional: concurrency for report/API calls inside the resync job (lower = less CPU)
RESYNC_WORKERS=3
